{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QxChat",
  "version": "0.1.0",
  "identifier": "com.kisakay.qxprotocol",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0",
    "devUrl": "http://localhost:4173",
    "beforeBuildCommand": "npm run build:tauri",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QxChat",
        "width": 1100,
        "height": 760,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "SocialNetworking",
    "copyright": "Copyright (c) QxChat",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "14.0",
      "developmentTeam": null
    }
  }
}
